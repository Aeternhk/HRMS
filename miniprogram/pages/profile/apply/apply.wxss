.apply-container {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 标签切换 */
.tab-bar {
  display: flex;
  background: #ffffff;
  border-bottom: 2rpx solid #f0f0f0;
}

.tab-item {
  flex: 1;
  padding: 32rpx;
  text-align: center;
  font-size: 30rpx;
  color: #666666;
  position: relative;
}

.tab-item.active {
  color: #0052D9;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background: #0052D9;
  border-radius: 2rpx;
}

/* 表单容器 */
.form-container {
  padding: 24rpx;
}

.form-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 0 32rpx;
  margin-bottom: 32rpx;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 32rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.form-item:last-child {
  border-bottom: none;
}

.form-item.textarea-item {
  flex-direction: column;
  align-items: flex-start;
}

.form-label {
  width: 160rpx;
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
}

.picker-value {
  flex: 1;
  font-size: 30rpx;
  color: #333333;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.arrow {
  font-size: 24rpx;
  color: #999999;
  margin-left: 16rpx;
}

.days-value {
  flex: 1;
  font-size: 30rpx;
  color: #0052D9;
  font-weight: 600;
  text-align: right;
}

.form-textarea {
  width: 100%;
  height: 200rpx;
  margin-top: 16rpx;
  padding: 24rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #333333;
  box-sizing: border-box;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  background: #0052D9;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 12rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.submit-btn::after {
  border: none;
}

.submit-btn.loading {
  background: #7a9fd9;
}

/* 历史记录 */
.history-container {
  padding: 24rpx;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.history-item {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.history-type {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.history-status {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  background: #E7E7E7;
  color: #666666;
}

.history-status.PENDING {
  background: #FFF3E0;
  color: #ED7B2F;
}

.history-status.APPROVED {
  background: #E8F5E9;
  color: #00A870;
}

.history-status.REJECTED {
  background: #FFEBEE;
  color: #E34D59;
}

.history-content {
  display: flex;
  flex-direction: column;
}

.history-detail {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.history-date {
  font-size: 24rpx;
  color: #999999;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 48rpx;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #999999;
}
