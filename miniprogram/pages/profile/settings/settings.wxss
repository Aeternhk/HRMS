.settings-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx;
  padding-bottom: 48rpx;
}

/* 设置卡片 */
.settings-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.card-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
}

/* 表单列表 */
.form-list {
  display: flex;
  flex-direction: column;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  width: 160rpx;
  font-size: 30rpx;
  color: #333333;
}

.form-input {
  flex: 1;
  height: 72rpx;
  padding: 0 24rpx;
  background: #f8f9fa;
  border-radius: 8rpx;
  font-size: 30rpx;
  color: #333333;
}

.save-btn {
  width: 100%;
  height: 88rpx;
  background: #0052D9;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 12rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 32rpx;
}

.save-btn::after {
  border: none;
}

.save-btn.loading {
  background: #7a9fd9;
}

/* 菜单列表 */
.menu-list {
  display: flex;
  flex-direction: column;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
}

.menu-title {
  font-size: 30rpx;
  color: #333333;
}

.menu-arrow {
  font-size: 32rpx;
  color: #CCCCCC;
}

.menu-divider {
  height: 2rpx;
  background: #f5f5f5;
}

/* 版本信息 */
.version-section {
  text-align: center;
  padding: 48rpx 24rpx;
}

.version-text {
  display: block;
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.copyright {
  font-size: 24rpx;
  color: #999999;
}
