.salary-container {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 月份选择 */
.month-tabs {
  background: #ffffff;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.month-scroll {
  white-space: nowrap;
  padding: 0 24rpx;
}

.month-item {
  display: inline-block;
  padding: 16rpx 32rpx;
  margin-right: 16rpx;
  background: #f5f5f5;
  border-radius: 32rpx;
  transition: all 0.3s;
}

.month-item.active {
  background: #0052D9;
}

.month-text {
  font-size: 28rpx;
  color: #666666;
}

.month-item.active .month-text {
  color: #ffffff;
}

/* 工资详情卡片 */
.salary-detail-card {
  background: #ffffff;
  margin: 24rpx;
  border-radius: 16rpx;
  padding: 32rpx;
}

.salary-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.salary-month {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.salary-status {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  background: #E7E7E7;
  color: #666666;
}

.salary-status.PAID {
  background: #E8F5E9;
  color: #00A870;
}

.salary-status.PENDING {
  background: #FFF3E0;
  color: #ED7B2F;
}

/* 工资总额 */
.salary-total {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 0;
  margin-bottom: 32rpx;
  background: linear-gradient(135deg, #FFF8E1 0%, #FFECB3 100%);
  border-radius: 16rpx;
}

.total-label {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 16rpx;
}

.total-value {
  font-size: 64rpx;
  font-weight: 700;
  color: #F57C00;
}

/* 工资明细区域 */
.salary-section {
  margin-bottom: 32rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.section-amount {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.section-amount.deduction {
  color: #E34D59;
}

.section-list {
  display: flex;
  flex-direction: column;
}

.section-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.item-name {
  font-size: 28rpx;
  color: #666666;
}

.item-value {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.item-value.deduction {
  color: #E34D59;
}

/* 备注 */
.salary-remark {
  padding: 24rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  margin-top: 24rpx;
}

.remark-label {
  font-size: 26rpx;
  color: #999999;
}

.remark-content {
  font-size: 26rpx;
  color: #666666;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 48rpx;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #999999;
}

/* 提示 */
.tips-section {
  text-align: center;
  padding: 32rpx;
}

.tips-text {
  font-size: 26rpx;
  color: #999999;
}
