/* ================================================
   首页样式 - 待办事项版
   ================================================ */

.index-container {
  min-height: 100vh;
  background: #f2f3f7;
  padding-bottom: 48rpx;
}

/* ===== 自定义 Header（替代导航栏） ===== */
.header-section {
  background: linear-gradient(135deg, #0052D9 0%, #1a6df0 60%, #003BB3 100%);
  padding: 0 32rpx 56rpx;
}

.header-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 24rpx;
}

.header-left {
  flex: 1;
}

.greeting {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 6rpx;
}

.department {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.header-right {
  text-align: right;
}

.header-date {
  display: inline-block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  background: rgba(255, 255, 255, 0.12);
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  letter-spacing: 1rpx;
}

/* ===== 考勤概况卡片 ===== */
.overview-card {
  margin: -32rpx 24rpx 20rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx 28rpx 24rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 82, 217, 0.12);
}

.overview-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.overview-title-area {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.overview-icon {
  font-size: 30rpx;
}

.overview-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
}

/* 今日状态徽标 */
.today-badge {
  font-size: 22rpx;
  padding: 8rpx 18rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.badge-pending {
  background: #f0f0f0;
  color: #999;
}

.badge-in {
  background: #E8F4FF;
  color: #0052D9;
}

.badge-done {
  background: #E8F7F0;
  color: #00A870;
}

/* 数字网格 */
.overview-grid {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 4rpx 0 16rpx;
}

.overview-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.ov-sep {
  width: 1rpx;
  height: 52rpx;
  background: #eee;
}

.ov-num {
  font-size: 46rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 6rpx;
  line-height: 1;
}

.ov-success { color: #00A870; }
.ov-warning { color: #ED7B2F; }
.ov-error   { color: #E34D59; }

.ov-label {
  font-size: 22rpx;
  color: #999;
}

/* 今日打卡时间行 */
.today-times {
  display: flex;
  gap: 16rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #f0f0f0;
}

.time-chip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: #f7f8fc;
  padding: 10rpx 18rpx;
  border-radius: 12rpx;
}

.chip-label {
  font-size: 22rpx;
  color: #999;
}

.chip-val {
  font-size: 26rpx;
  font-weight: 600;
  color: #0052D9;
}

/* ===== Section 通用 ===== */
.section {
  margin: 0 24rpx 20rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.section-more {
  font-size: 24rpx;
  color: #999;
}

/* ===== 待办事项列表 ===== */
.todo-list {
  /* 容器 */
}

/* 单个待办项 */
.todo-item {
  display: flex;
  align-items: center;
  padding: 24rpx 20rpx;
  background: #fafbfc;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  border-left: 6rpx solid transparent;
  transition: all 0.2s ease;
}

.todo-item:last-child {
  margin-bottom: 0;
}

.todo-item:active {
  transform: scale(0.98);
  opacity: 0.9;
}

/* 打卡待办 - 蓝色主题 */
.todo-clock-item {
  background: #EFF5FF;
  border-left-color: #0052D9;
}

/* 投票待办 - 橙色主题 */
.todo-vote-item {
  background: #FFF8F0;
  border-left-color: #ED7B2F;
}

/* 待办图标 */
.todo-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.todo-icon-blue {
  background: linear-gradient(135deg, #EEF4FF 0%, #DCE8FF 100%);
}

.todo-icon-orange {
  background: linear-gradient(135deg, #FFF6ED 0%, #FFECD6 100%);
}

.todo-icon-text {
  font-size: 36rpx;
}

/* 待办文字信息 */
.todo-info {
  flex: 1;
  min-width: 0;
}

.todo-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 6rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.todo-desc {
  display: block;
  font-size: 22rpx;
  color: #999;
}

/* 操作按钮 */
.todo-action {
  margin-left: 12rpx;
  flex-shrink: 0;
}

.todo-btn {
  display: inline-block;
  font-size: 24rpx;
  font-weight: 600;
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
  white-space: nowrap;
}

.todo-btn-blue {
  color: #0052D9;
  background: #DCE8FF;
}

.todo-btn-orange {
  color: #ED7B2F;
  background: #FFECD6;
}

/* 待办空状态 */
.todo-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 16rpx;
}

.todo-empty-icon {
  font-size: 56rpx;
  margin-bottom: 12rpx;
}

.todo-empty-text {
  font-size: 26rpx;
  color: #bbb;
}

/* ===== 公告列表 ===== */
.notice-item {
  display: flex;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.notice-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.notice-item:first-child {
  padding-top: 0;
}

.notice-tag {
  flex-shrink: 0;
  font-size: 20rpx;
  color: #ffffff;
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
  font-weight: 500;
}

.notice-body {
  flex: 1;
  min-width: 0;
}

.notice-title {
  display: block;
  font-size: 28rpx;
  color: #1a1a1a;
  font-weight: 500;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-bottom: 4rpx;
}

.notice-time {
  font-size: 22rpx;
  color: #bbb;
}

.notice-arrow {
  font-size: 36rpx;
  color: #ccc;
  margin-left: 12rpx;
  font-weight: 300;
  flex-shrink: 0;
}

/* 暂无公告 */
.empty-notice {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 36rpx 0 16rpx;
}

.empty-icon {
  font-size: 52rpx;
  margin-bottom: 14rpx;
}

.empty-text {
  font-size: 26rpx;
  color: #bbb;
}
