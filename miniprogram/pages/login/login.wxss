.login-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #0052D9 0%, #003BB3 100%);
  display: flex;
  flex-direction: column;
  padding: 80rpx 48rpx;
  box-sizing: border-box;
}

/* Logo区域 */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  background: #ffffff;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.2);
}

.logo-icon {
  font-size: 64rpx;
  font-weight: bold;
  color: #0052D9;
}

.app-name {
  font-size: 40rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 16rpx;
}

.app-slogan {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 登录表单 */
.login-form {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 48rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
}

.form-item {
  margin-bottom: 32rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.input {
  width: 100%;
  height: 88rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #333333;
  box-sizing: border-box;
}

.input::placeholder {
  color: #999999;
}

/* 记住我 */
.remember-section {
  display: flex;
  align-items: center;
  margin-bottom: 48rpx;
}

.remember-text {
  font-size: 26rpx;
  color: #666666;
  margin-left: 8rpx;
}

/* 登录按钮 */
.login-btn {
  width: 100%;
  height: 96rpx;
  background: #0052D9;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 12rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-btn::after {
  border: none;
}

.login-btn.loading {
  background: #7a9fd9;
}

/* 提示信息 */
.tips {
  text-align: center;
  margin-top: 32rpx;
}

.tips-text {
  font-size: 24rpx;
  color: #999999;
}

/* 底部版权 */
.footer {
  margin-top: auto;
  padding-top: 48rpx;
  text-align: center;
}

.copyright {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}
