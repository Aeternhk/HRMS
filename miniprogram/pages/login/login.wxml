<view class="login-container">
  <!-- Logo区域 -->
  <view class="logo-section">
    <view class="logo">
      <text class="logo-icon">HR</text>
    </view>
    <text class="app-name">HRMS人力资源系统</text>
    <text class="app-slogan">智慧考勤 · 便捷办公</text>
  </view>

  <!-- 登录表单 -->
  <view class="login-form">
    <view class="form-item">
      <text class="label">工号/手机号</text>
      <input 
        class="input" 
        type="text" 
        placeholder="请输入工号或手机号"
        value="{{username}}"
        bindinput="onUsernameInput"
      />
    </view>

    <view class="form-item">
      <text class="label">密码</text>
      <input 
        class="input" 
        type="password" 
        placeholder="请输入密码"
        value="{{password}}"
        bindinput="onPasswordInput"
      />
    </view>

    <!-- 记住我 -->
    <view class="remember-section">
      <checkbox checked="{{rememberMe}}" bindtap="onRememberChange" color="#0052D9"/>
      <text class="remember-text">记住登录状态（7天）</text>
    </view>

    <!-- 登录按钮 -->
    <button 
      class="login-btn {{loading ? 'loading' : ''}}" 
      bindtap="onLogin"
      disabled="{{loading}}"
    >
      {{loading ? '登录中...' : '登 录'}}
    </button>

    <!-- 提示信息 -->
    <view class="tips">
      <text class="tips-text">如忘记密码，请联系人事部门重置</text>
    </view>
  </view>

  <!-- 底部版权 -->
  <view class="footer">
    <text class="copyright">© 2026 HRMS 人力资源管理系统</text>
  </view>
</view>
