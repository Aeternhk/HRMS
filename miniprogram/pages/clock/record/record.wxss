.record-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx;
}

/* 月份选择 */
.month-picker {
  background: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.picker-content {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
}

.month-text {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  margin-right: 16rpx;
}

.arrow {
  font-size: 24rpx;
  color: #999999;
}

/* 月度统计卡片 */
.stats-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.stats-header {
  margin-bottom: 24rpx;
}

.stats-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.stats-grid {
  display: flex;
  justify-content: space-around;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 26rpx;
  color: #999999;
}

.text-success {
  color: #00A870;
}

.text-warning {
  color: #ED7B2F;
}

.text-error {
  color: #E34D59;
}

/* 打卡记录列表 */
.record-list {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
}

.list-header {
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.header-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.record-items {
  display: flex;
  flex-direction: column;
}

.record-item {
  display: flex;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.record-item:last-child {
  border-bottom: none;
}

.record-date {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 120rpx;
  padding-right: 24rpx;
  border-right: 2rpx solid #f0f0f0;
}

.day {
  font-size: 40rpx;
  font-weight: 700;
  color: #333333;
}

.week {
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
}

.record-detail {
  flex: 1;
  padding-left: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.time-row {
  display: flex;
  align-items: center;
}

.time-label {
  width: 80rpx;
  font-size: 26rpx;
  color: #999999;
}

.time-value {
  flex: 1;
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
}

.status-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  margin-left: 16rpx;
}

.status-tag.normal {
  background: #E8F5E9;
  color: #00A870;
}

.status-tag.late {
  background: #FFF3E0;
  color: #ED7B2F;
}

.status-tag.early {
  background: #FFF3E0;
  color: #ED7B2F;
}

.status-tag.absent {
  background: #FFEBEE;
  color: #E34D59;
}

/* 加载状态 */
.load-more, .no-more {
  text-align: center;
  padding: 32rpx;
}

.load-more text, .no-more text {
  font-size: 26rpx;
  color: #999999;
}
