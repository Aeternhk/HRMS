<view class="detail-container">
  <!-- 加载中 -->
  <view class="loading-state" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <!-- 投票详情 -->
  <block wx:if="{{!loading && voteDetail}}">
    <!-- ========== 投票信息卡片（始终显示）========== -->
    <view class="vote-info-card">
      <view class="vote-type-tag">{{voteDetail._typeName}}</view>
      <text class="vote-title">{{voteDetail.title}}</text>
      <text class="vote-desc" wx:if="{{voteDetail.description}}">{{voteDetail.description}}</text>
      <view class="vote-meta">
        <text class="meta-item" wx:if="{{!showResult}}">截止时间：{{voteDetail.endTime}}</text>
        <text class="meta-item" wx:if="{{showResult}}">{{totalVotes}}人参与</text>
        <text class="meta-item" wx:if="{{!showResult && voteDetail.participantCount}}">{{voteDetail.participantCount}}人已参与</text>
      </view>
    </view>

    <!-- ============ 未投票：投票选项 + 提交按钮 ============ -->
    <block wx:if="{{!showResult}}">
      <!-- 选项卡片 -->
      <view class="options-card">
        <view class="options-header">
          <text class="options-title">投票选项</text>
          <text class="options-tip" wx:if="{{voteDetail.type === 'MULTI'}}">
            最多选择{{voteDetail.maxSelections || optionsWithState.length}}项
          </text>
        </view>

        <!-- 单选/多选（使用 _selected 数据字段判断） -->
        <view wx:if="{{voteDetail.type === 'SINGLE' || voteDetail.type === 'MULTI'}}">
          <view
            class="option-item {{item._selected ? 'selected' : ''}}"
            wx:for="{{optionsWithState}}"
            wx:key="id"
            data-id="{{item.id}}"
            bindtap="{{voteDetail.type === 'SINGLE' ? 'onSingleSelect' : 'onMultiSelect'}}"
          >
            <view class="option-radio">
              <view class="radio-inner" wx:if="{{item._selected}}"></view>
            </view>
            <text class="option-text">{{item.content}}</text>
          </view>
        </view>

        <!-- 评分投票 -->
        <view wx:if="{{voteDetail.type === 'SCORE'}}">
          <view class="score-item" wx:for="{{optionsWithState}}" wx:key="id">
            <text class="score-label">{{item.content}}</text>
            <slider
              class="score-slider"
              min="1"
              max="5"
              step="1"
              show-value
              value="{{scoreValues[item.id] || 3}}"
              data-id="{{item.id}}"
              bindchange="onScoreChange"
            />
          </view>
        </view>
      </view>

      <!-- 提交按钮 -->
      <view class="submit-section">
        <button
          class="submit-btn {{submitting ? 'loading' : ''}}"
          bindtap="onSubmit"
          disabled="{{submitting}}"
        >
          {{submitting ? '提交中...' : '提交投票'}}
        </button>
      </view>
    </block>

    <!-- ============ 已投票/已结束：结果卡片 ============ -->
    <block wx:if="{{showResult}}">
      <view class="result-card">
        <view class="result-header">
          <text class="result-title">📊 投票结果</text>
          <text class="result-status" wx:if="{{hasVoted}}">✓ 你已投票</text>
        </view>

        <!-- 结果列表（已按票数从多到少排序） -->
        <view class="result-list">
          <view class="result-item {{index < 3 ? 'top-rank' : ''}}" wx:for="{{resultData}}" wx:key="id">
            <!-- 排名 + 内容 + 票数 -->
            <view class="result-left">
              <view class="rank-badge {{index === 0 ? 'gold' : index === 1 ? 'silver' : index === 2 ? 'bronze' : ''}}">
                {{index + 1}}
              </view>
              <text class="result-option-name">{{item.content}}</text>
            </view>

            <!-- 进度条区域 -->
            <view class="result-bar-area">
              <view class="result-bar-track">
                <view
                  class="result-bar-fill {{index === 0 ? 'bar-gold' : ''}}"
                  style="width: {{item.percentage > 0 ? item.percentage : (item.voteCount > 0 ? 5 : 1)}}%;"
                ></view>
              </view>
              <view class="result-stats">
                <text class="result-votes">{{item.voteCount}}票</text>
                <text class="result-percent">{{item.percentage}}%</text>
              </view>
            </view>
          </view>
        </view>

        <!-- 无数据提示 -->
        <view class="empty-result" wx:if="{{resultData.length === 0}}">
          <text>暂无投票数据</text>
        </view>
      </view>

      <!-- 返回按钮 -->
      <view class="back-section">
        <button class="back-btn" bindtap="goBack">返回投票列表</button>
      </view>
    </block>
  </block>
</view>
