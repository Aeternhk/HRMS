.vote-container {
  min-height: 100vh;
  background: #f2f3f7;
}

/* 标签切换 */
.tab-bar {
  display: flex;
  background: #ffffff;
  padding: 0 32rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.tab-item {
  position: relative;
  padding: 32rpx 48rpx;
  font-size: 30rpx;
  color: #666666;
  transition: all 0.3s;
}

.tab-item.active {
  color: #0052D9;
  font-weight: 600;
}

.tab-line {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background: #0052D9;
  border-radius: 2rpx;
}

/* 投票列表 */
.vote-list {
  padding: 24rpx;
}

.vote-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.vote-card:active {
  opacity: 0.8;
}

.ended-card,
.vote-card.ended {
  opacity: 0.75;
}

.vote-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

/* 投票类型标签 */
.vote-type-tag {
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  background: #EEF4FF;
  color: #0052D9;
  border-radius: 8rpx;
  font-weight: 500;
}

/* 状态标签 */
.vote-status-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.tag-pending {
  background: #FFF3E0;
  color: #ED7B2F;
}

.tag-voted {
  background: #E8F7F0;
  color: #00A870;
}

.tag-ended {
  background: #f5f5f5;
  color: #999;
}

.vote-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 16rpx;
  line-height: 1.5;
}

.vote-desc {
  display: block;
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 24rpx;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.vote-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid #f5f5f5;
}

.vote-time {
  font-size: 24rpx;
  color: #aaa;
}

.vote-count {
  font-size: 24rpx;
  color: #0052D9;
  font-weight: 500;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 48rpx;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #bbb;
}

/* 加载/更多 */
.loading-row {
  text-align: center;
  padding: 32rpx;
  color: #bbb;
  font-size: 26rpx;
}

.load-more {
  text-align: center;
  padding: 32rpx;
}

.load-more text {
  font-size: 26rpx;
  color: #0052D9;
}
